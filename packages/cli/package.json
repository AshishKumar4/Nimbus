{
  "name": "@nimbus-sh/cli",
  "version": "0.1.0",
  "description": "Nimbus CLI — `create-nimbus-app` scaffolder + `token mint` + `runtime sync`.",
  "homepage": "https://github.com/AshishKumar4/Nimbus",
  "repository": {
    "type": "git",
    "url": "https://github.com/AshishKumar4/Nimbus.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/AshishKumar4/Nimbus/issues",
  "license": "MIT",
  "type": "module",
  "bin": {
    "nimbus": "./src/bin.ts",
    "create-nimbus-app": "./src/scaffold-bin.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "workspace": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "templates",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nimbus-sh/sdk": "workspace:^"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@nimbus-sh/sdk": "workspace:^",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
