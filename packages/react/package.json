{
  "name": "@nimbus-sh/react",
  "version": "0.1.0",
  "description": "React component for embedding a Nimbus terminal in your app. <NimbusTerminal /> is a typed iframe wrapper with token + tenant props.",
  "homepage": "https://github.com/AshishKumar4/Nimbus",
  "repository": {
    "type": "git",
    "url": "https://github.com/AshishKumar4/Nimbus.git",
    "directory": "packages/react"
  },
  "bugs": "https://github.com/AshishKumar4/Nimbus/issues",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "workspace": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "@nimbus-sh/sdk": "workspace:^"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@nimbus-sh/sdk": "workspace:^",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
