{
  "name": "@nimbus-sh/config",
  "version": "0.1.0",
  "description": "Typed wrangler-config helper for Nimbus embedders. Generates a valid wrangler.jsonc from one function call.",
  "homepage": "https://github.com/AshishKumar4/Nimbus",
  "repository": {
    "type": "git",
    "url": "https://github.com/AshishKumar4/Nimbus.git",
    "directory": "packages/config"
  },
  "bugs": "https://github.com/AshishKumar4/Nimbus/issues",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "workspace": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
