{
  "name": "nimbus-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "bundle": "bun run --cwd packages/worker bundle",
    "predev": "bun run bundle",
    "predeploy": "bun run bundle",
    "dev": "bun run --cwd apps/dogfood dev",
    "deploy": "bun run --cwd apps/dogfood deploy",
    "deploy:production": "bun run --cwd apps/dogfood deploy:production",
    "typecheck": "./node_modules/.bin/tsc --noEmit",
    "test:behavioral": "bun tests/behavioral/run-all.mjs",
    "postinstall": "node packages/worker/scripts/patch-lifo-ui.mjs && node packages/worker/scripts/bundle-git.mjs && node packages/worker/scripts/bundle-facet-workers.mjs && node packages/worker/scripts/bundle-esbuild-wasm.mjs && node packages/worker/scripts/bundle-tailwind-play.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "2.3.7",
    "@cloudflare/workers-types": "^4.20250327.0",
    "esbuild": "^0.27.0",
    "puppeteer": "^24.43.0",
    "puppeteer-core": "^24.42.0",
    "typescript": "^5.7.0",
    "wabt": "^1.0.39",
    "wrangler": "^4.0.0"
  }
}
